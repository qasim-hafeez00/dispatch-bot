# ============================================================
# CortexBot — Phase 2 Complete Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=CortexBot
APP_VERSION=2.0.0
ENVIRONMENT=development

# Your public URL — use ngrok URL for development
# Get from: ngrok http 8000
BASE_URL=https://YOUR-NGROK-URL.ngrok-free.app

# ── Database (Docker default — don't change for local dev) ──
DATABASE_URL=postgresql+asyncpg://cortex:cortex@postgres:5432/cortexbot
DATABASE_URL_SYNC=postgresql://cortex:cortex@postgres:5432/cortexbot

# ── Redis (Docker default) ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string-in-production
NGROK_TOKEN=YOUR_NGROK_TOKEN

# ── AI Models ─────────────────────────────────────────────────
# Claude: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI GPT-4o-mini (for email classification)
# https://platform.openai.com
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Bland AI (Phone Calls) ────────────────────────────────────
# https://app.bland.ai → Settings → API Key
BLAND_AI_API_KEY=your-bland-api-key
BLAND_AI_CALLER_ID=+1XXXXXXXXXX

# ── Twilio (WhatsApp + SMS) ───────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886   # Sandbox number
TWILIO_SMS_NUMBER=+1XXXXXXXXXX

# ── SendGrid (Email) ──────────────────────────────────────────
# https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=dispatch@yourdomain.com
SENDGRID_FROM_NAME=CortexBot Dispatch

# ── DAT API (Load Board + Rate Data) ─────────────────────────
# https://developer.dat.com — request API access
DAT_CLIENT_ID=your-dat-client-id
DAT_CLIENT_SECRET=your-dat-client-secret

# ── FMCSA SAFER API ──────────────────────────────────────────
# https://mobile.fmcsa.dot.gov/QCDevsite/docs/quickLinks
FMCSA_API_KEY=your-fmcsa-api-key

# ── Highway.com (Freight Guard / Fraud Detection) ─────────────
# https://usehighway.com — request API access
HIGHWAY_API_KEY=your-highway-api-key

# ── AWS ────────────────────────────────────────────────────────
# https://console.aws.amazon.com → IAM → Create User
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=cortexbot-docs

# ── DocuSign ───────────────────────────────────────────────────
# https://developers.docusign.com → Apps and Keys
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOCUSIGN_SECRET_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ── Google Maps ───────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services
# Enable: Maps Directions API, Distance Matrix API, Geocoding API
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── ELD Providers ─────────────────────────────────────────────
# Samsara: https://cloud.samsara.com/api-tokens
SAMSARA_API_KEY=samsara_api_...

# Motive (KeepTruckin): https://app.keeptruckin.com/oauth/applications
MOTIVE_API_KEY=your-motive-api-key

# ── Stripe (Driver ACH Settlements) ──────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── EFS Fuel Card ────────────────────────────────────────────
# https://efspay.com — request API access
EFS_API_KEY=your-efs-api-key

# ── Comdata Fuel Card ─────────────────────────────────────────
# https://comdata.com — request API access
COMDATA_API_KEY=your-comdata-api-key

# ── QuickBooks Online ─────────────────────────────────────────
# https://developer.intuit.com → Create App
QUICKBOOKS_CLIENT_ID=your-qbo-client-id
QUICKBOOKS_CLIENT_SECRET=your-qbo-client-secret
QUICKBOOKS_COMPANY_ID=your-qbo-company-id

# ── Escalation (Your on-call phone + email) ───────────────────
ONCALL_PHONE=+1XXXXXXXXXX
ONCALL_EMAIL=you@yourdomain.com
